# ============================================================
# IronShield Atomic Arbitrage Engine v3.1 - Environment Config
# ============================================================

# ---- CRITICAL: Private Key for Transaction Signing ----
# WARNING: Never commit this file with real keys!
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ---- RPC Endpoints (Use PRIVATE endpoints only!) ----
# Primary RPC (Alchemy / QuickNode / Tatum)
BASE_RPC_URL=https://base-mainnet.gateway.tatum.io
# Fallback RPC (optional, uses primary if not set)
BASE_RPC_FALLBACK=https://base-mainnet.gateway.tatum.io

# Tatum API Key (required if using Tatum as RPC provider)
TATUM_API_KEY=YOUR_TATUM_API_KEY

# ---- BaseScan API (for contract verification) ----
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY

# ---- Deployed Contract Address (set after deployment) ----
EXECUTOR_CONTRACT_ADDRESS=

# ---- Execution Parameters ----
MIN_PROFIT_USD=1.50
MAX_GAS_PRICE_GWEI=5
DEFAULT_LOAN_AMOUNT=1000000000000000000
SIMULATION_ITERATIONS=1000

# ---- Scanner Parameters ----
SCAN_INTERVAL_MS=2000
MIN_SPREAD_PCT=0.8
MIN_MARKET_CAP=20000
MAX_MARKET_CAP=200000

# ---- RPC Rate Limiting (v3.1) ----
RPC_MAX_RPS=10
RPC_BURST_CAPACITY=15
POOL_SCAN_CHUNK_SIZE=5
POOL_SCAN_JITTER_MS=50

# ---- Logging ----
LOG_LEVEL=info
LOG_DIR=./logs

# ---- Gas Reporter (optional) ----
REPORT_GAS=true
